//Database connection configuration
MYSQL_HOST=---
MYSQL_PORT=---
MYSQL_USER=---
MYSQL_PASSWORD=---
MYSQL_DATABASE=---

//Server configuration
PORT=3003
DOMAIN=http://localhost:3000

//JWT Configuration
JWT_SECRET=sua-chave-secreta-para-access-token
JWT_REFRESH_SECRET=sua-chave-secreta-para-refresh-token
JWT_RESET_SECRET=sua-chave-secreta-para-reset-token
JWT_VERIFY_SECRET=sua-chave-secreta-para-verify-token

//Email Configuration (para funcionalidades de envio de email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASSWORD=sua-senha-de-aplicacao
SMTP_FROM=noreply@mycdrecords.com

//Frontend URLs
FRONTEND_URL=http://localhost:3000
FRONTEND_RESET_PASSWORD_URL=http://localhost:3000/auth/reset-password
FRONTEND_VERIFY_EMAIL_URL=http://localhost:3000/auth/verify-email

//OAuth Configuration (opcional)
GOOGLE_CLIENT_ID=seu-google-client-id
GOOGLE_CLIENT_SECRET=seu-google-client-secret

SPOTIFY_CLIENT_ID=seu-spotify-client-id
SPOTIFY_CLIENT_SECRET=seu-spotify-client-secret

DISCORD_CLIENT_ID=seu-discord-client-id
DISCORD_CLIENT_SECRET=seu-discord-client-secret