{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "rootDir": "./src",
    "outDir": "../dist",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true,

    "resolveJsonModule": true,
    "moduleResolution": "node",

    "types": ["node"],
    "sourceMap": true,
    "ignoreDeprecations": "6.0",
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}